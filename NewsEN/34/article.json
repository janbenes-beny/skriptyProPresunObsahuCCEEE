 height=\"285\" alt=\"\"></a></div><div class=\"rl-gallery-item\"><a href=\"https://www.ccee.eu/wp-content/uploads/sites/2/2025/03/482091072_613910468280420_1863837793693271948_n.jpg\" title=\"\" data-rl_title=\"\" class=\"rl-gallery-link swipebox\" data-rl_caption=\"\" data-rel=\"lightbox-gallery-1\"><img loading=\"lazy\" decoding=\"async\" src=\"https://www.ccee.eu/wp-content/uploads/sites/2/2025/03/482091072_613910468280420_1863837793693271948_n-380x285.jpg\" width=\"380\" height=\"285\" alt=\"\"></a></div><div class=\"rl-gallery-item\"><a href=\"https://www.ccee.eu/wp-content/uploads/sites/2/2025/03/482092026_614739344864199_2499379820858258028_n-1.jpg\" title=\"\" data-rl_title=\"\" class=\"rl-gallery-link swipebox\" data-rl_caption=\"\" data-rel=\"lightbox-gallery-1\"><img loading=\"lazy\" decoding=\"async\" src=\"https://www.ccee.eu/wp-content/uploads/sites/2/2025/03/482092026_614739344864199_2499379820858258028_n-1-380x285.jpg\" width=\"380\" height=\"285\" alt=\"\"></a></div><div class=\"rl-gallery-item\"><a href=\"https://www.ccee.eu/wp-content/uploads/sites/2/2025/03/482251604_614739528197514_2997153818673153488_n.jpg\" title=\"\" data-rl_title=\"\" class=\"rl-gallery-link swipebox\" data-rl_caption=\"\" data-rel=\"lightbox-gallery-1\"><img loading=\"lazy\" decoding=\"async\" src=\"https://www.ccee.eu/wp-content/uploads/sites/2/2025/03/482251604_614739528197514_2997153818673153488_n-380x285.jpg\" width=\"380\" height=\"285\" alt=\"\"></a></div><div class=\"rl-gallery-item\"><a href=\"https://www.ccee.eu/wp-content/uploads/sites/2/2025/03/482252891_614765141528286_9366291579071857_n.jpg\" title=\"\" data-rl_title=\"\" class=\"rl-gallery-link swipebox\" data-rl_caption=\"\" data-rel=\"lightbox-gallery-1\"><img loading=\"lazy\" decoding=\"async\" src=\"https://www.ccee.eu/wp-content/uploads/sites/2/2025/03/482252891_614765141528286_9366291579071857_n-380x298.jpg\" width=\"380\" height=\"298\" alt=\"\"></a></div><div class=\"rl-gallery-item\"><a href=\"https: