<article id="post-42117" class="post-42117 post type-post status-publish format-standard has-post-thumbnail hentry category-archivio category-comissions category-news-2025 category-news category-vocations category-youth ambiti-giovani ambiti-vocazioni" itemtype="http://schema.org/CreativeWork" itemscope="itemscope">
